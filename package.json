{
  "name": "rwk-multibox-client",
  "version": "1.0",
  "private": true,
  "license": "Unlicense",
  "description": "GM-sanctioned multiboxing client for Race War Kingdoms: character vault, controller + child client windows, fleet hotkey broadcast of built-in RWK keybinds. No automation.",
  "type": "commonjs",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "build": "electron-vite build",
    "test": "tsx --test tests/characterImportExport.test.ts tests/hotkeys.test.ts tests/characterStore.test.ts tests/parentVaultImport.test.ts",
    "dist": "node scripts/dist.cjs",
    "clean:release": "node -e \"require('fs').rmSync('release-rwk-multibox',{recursive:true,force:true})\""
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "local.rwk-multibox-client",
    "productName": "RWK Multibox",
    "directories": {
      "output": "release-rwk-multibox"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "RWK-Multibox-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "RWK-Multibox-Portable-${version}.${ext}"
    }
  }
}
